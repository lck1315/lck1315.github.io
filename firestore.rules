rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isMaster() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == '아빠 👨';
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        isMaster() || 
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isApproved']))
      );
      allow delete: if isMaster();
    }

    match /workIdeas/{document} {
      allow read, write: if true;
    }

    match /workMemberChats/{document} {
      allow read, write: if true;
    }

    match /{collection}/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && collection != 'users';
    }
  }
}